{
    "name": "@buntui/core",
    "version": "0.1.0-alpha.3",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/AlphaFoxz/buntui.git",
        "directory": "packages/core"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./global": {
            "types": "./dist/global.d.ts",
            "default": "./dist/global.d.ts"
        },
        "./platform": {
            "browser": {
                "types": "./dist/platform/browser.d.ts",
                "default": "./dist/platform/browser.js"
            },
            "types": "./dist/platform/native.d.ts",
            "default": "./dist/platform/native.js"
        }
    },
    "files": [
        "dist/"
    ],
    "sideEffects": false,
    "scripts": {
        "test": "bun test",
        "build": "tsc --project ./tsconfig.json && node -e \"require('fs').copyFileSync('src/global.d.ts','dist/global.d.ts')\"",
        "sync": "bun run ./scripts/sync.ts"
    },
    "dependencies": {
        "@buntui/native": "workspace:*"
    },
    "devDependencies": {
        "@types/bun": "^1.3.14",
        "string-width": "^8.2.1"
    }
}
