{
    "name": "github-pages",
    "version": "0.1.0-alpha.3",
    "private": true,
    "type": "module",
    "scripts": {
        "copy-wasm": "bun run scripts/copy-wasm.ts",
        "dev": "bun run copy-wasm && vite",
        "build": "bun run copy-wasm && run-p type-check \"build-only {@}\" --",
        "preview": "vite preview",
        "test:unit": "vitest",
        "build-only": "vite build",
        "type-check": "vue-tsc --build"
    },
    "dependencies": {
        "@buntui/core": "workspace:*",
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/xterm": "^6.0.0",
        "vue": "^3.5.35",
        "vue-router": "^5.1.0"
    },
    "devDependencies": {
        "@tsconfig/node24": "^24.0.4",
        "@types/jsdom": "^28.0.3",
        "@types/node": "^24.12.4",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vue/test-utils": "^2.4.10",
        "@vue/tsconfig": "^0.9.1",
        "jsdom": "^29.1.1",
        "npm-run-all2": "^8.0.4",
        "typescript": "~6.0.3",
        "vite": "^8.0.16",
        "vite-plugin-vue-devtools": "^8.1.2",
        "vitest": "^4.1.8",
        "vue-tsc": "^3.3.3"
    },
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    }
}
