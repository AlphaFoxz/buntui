{
    "name": "buntui",
    "version": "0.1.0-alpha.5",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/AlphaFoxz/buntui.git",
        "directory": "packages/buntui"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist/"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "bun build --target=bun --production ./src/index.ts --outfile ./dist/index.js --external @buntui/core --external @buntui/extensions && tsc --project ./tsconfig.json"
    },
    "dependencies": {
        "@buntui/core": "workspace:*",
        "@buntui/extensions": "workspace:*"
    },
    "devDependencies": {
        "@types/bun": "1.3.14"
    }
}
