{
    "compilerOptions": {
        "lib": ["ESNext"],
        "target": "ESNext",
        "module": "Preserve",
        "moduleDetection": "force",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "declaration": true,
        "emitDeclarationOnly": true,
        "outDir": "dist",
        "strict": true,
        "skipLibCheck": true,
        "erasableSyntaxOnly": true,
        "types": ["bun"]
    },
    "include": [
        "src/lib/config.ts",
        "src/config.ts"
    ]
}
