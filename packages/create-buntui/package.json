{
    "name": "create-buntui",
    "version": "0.1.0-alpha.2",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/AlphaFoxz/buntui.git",
        "directory": "packages/create-buntui"
    },
    "bin": {
        "create-buntui": "./dist/index.js"
    },
    "files": [
        "dist/",
        "templates/"
    ],
    "scripts": {
        "build": "bun run ./scripts/build.ts",
        "dev": "bun --preload @buntui/compiler/vue-plugin ./src/index.ts"
    },
    "dependencies": {
        "@buntui/core": "workspace:*"
    },
    "devDependencies": {
        "@buntui/compiler": "workspace:*",
        "@buntui/native": "workspace:*",
        "@vue/reactivity": "^3.5.34",
        "@types/bun": "^1.3.14"
    }
}
