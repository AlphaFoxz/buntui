{
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "prettier.tabWidth": 4,
    "xo.enable": true,
    "xo.format.enable": true,
    "[zig]": {
        "editor.defaultFormatter": "ziglang.vscode-zig",
    },
    "[typescript]": {
        "editor.tabSize": 2,
        "editor.defaultFormatter": "samverschueren.linter-xo"
    },
    "[markdown]": {
        "editor.tabSize": 2,
        "prettier.tabWidth": 2
    },
    "[vue]": {
        "editor.tabSize": 2,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "prettier.printWidth": 80
    },
    "zig.debugTestArgs": [
        "test",
        "${path}",
        "--test-filter",
        "${filter}",
        "-lc",
        "--test-no-exec",
        "-femit-bin=${binaryPath}"
    ],
    "zig.testArgs": [
        "test",
        "--test-filter",
        "${filter}",
        "${path}",
        "-lc",
    ]
}