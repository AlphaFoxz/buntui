{
    "name": "buntui",
    "version": "0.1.0-alpha.2",
    "private": true,
    "scripts": {
        "build": "bun run sync && bun run ./scripts/build.ts",
        "check": "bunx xo --fix --config ./xo.config.ts",
        "dev": "bun run --cwd ./packages/playground dev",
        "cli": "bun --cwd ./packages/create-buntui dev",
        "sync": "bun run ./scripts/sync-version.ts",
        "test": "bun test:zig && bun test:ts",
        "test:ts": "bun test --coverage --parallel",
        "test:zig": "bun run --cwd ./packages/native zig-test"
    },
    "devDependencies": {
        "@types/bun": "^1.3.14",
        "eslint-config-xo-typescript": "^11.0.0",
        "vue-tsc": "^3.3.1",
        "xo": "^2.0.2"
    },
    "peerDependencies": {
        "typescript": "^5.9.3"
    },
    "workspaces": [
        "packages/*",
        "packages/native-platforms/*"
    ]
}
